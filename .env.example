# ============ OJ 平台环境配置 ============
# 启动脚本会在缺少 .env 时自动复制本文件为 .env。
# 本地体验用默认值即可；对外部署务必修改密钥与密码。

# 对外访问端口（浏览器访问 http://localhost:此端口）
HTTP_PORT=8080

# ---- Django ----
DJANGO_SECRET_KEY=change-me-please-use-a-long-random-string
DJANGO_DEBUG=False
# 允许的主机名（经 Nginx 代理，按浏览器使用的主机匹配）
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# 邮件链接（验证邮箱 / 找回密码）使用的前端地址，需与 HTTP_PORT 一致
FRONTEND_URL=http://localhost:8080

# ---- 数据库 ----
POSTGRES_DB=oj
POSTGRES_USER=oj
POSTGRES_PASSWORD=oj

# ---- 首次启动初始化 ----
# 置 1 会创建演示数据：管理员 admin / admin12345 + 示例题 #1（A+B，含测试点）。
# 该命令幂等，重复启动不会重复创建；体验完可改回 0。
SEED_DEMO=1

# ---- 进程并发（按机器配置可调）----
GUNICORN_WORKERS=3
CELERY_CONCURRENCY=2

# ============ 国内构建加速源 ============
# 在中国大陆构建镜像时保留以下默认值即可；境外构建可改回上游或置空。
# 说明：基础镜像(postgres/redis/python/debian/node/nginx)的“拉取”不在这里，
# 而是由 Docker Desktop 的“镜像加速器”负责，见 README-部署 与 deploy/daemon.json.example。

# Debian apt 镜像（清华 TUNA）——后端与沙箱镜像安装系统包用
APT_MIRROR=mirrors.tuna.tsinghua.edu.cn
# PyPI 镜像（清华 TUNA）——后端 pip 安装用
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# npm 镜像（npmmirror 淘宝源）——前端依赖安装用
NPM_REGISTRY=https://registry.npmmirror.com
# GitHub 下载代理——拉取 go-judge 二进制用；必须以 / 结尾，置空 (GH_PROXY=) 则直连。
# 若该域名失效：可改 https://github.akams.cn/ ，或到 https://ghproxy.link/ 查当前可用域名。
GH_PROXY=https://ghfast.top/
# go-judge 版本
GOJUDGE_VERSION=1.12.0

# ---- 邮件（默认打印到后端日志，无需真实邮箱）----
# 如需真实发信，改为 SMTP 后端并填写下列参数：
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=465
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=your-password
# EMAIL_USE_SSL=True
# DEFAULT_FROM_EMAIL=OJ <no-reply@example.com>
