# 复制为 .env 并按需修改
DJANGO_SECRET_KEY=dev-secret-change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# 数据库（PostgreSQL）
POSTGRES_DB=oj
POSTGRES_USER=oj
POSTGRES_PASSWORD=oj
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Redis（Celery broker + 缓存）
REDIS_URL=redis://127.0.0.1:6379/0

# 前端地址（用于邮件里的验证/重置链接）
FRONTEND_URL=http://localhost:5173

# 邮件服务（开发默认走 console，生产填 SMTP）
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=465
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_SSL=True
DEFAULT_FROM_EMAIL=OJ System <no-reply@example.com>

# 判题沙箱后端：local（仅开发，无隔离！）/ 生产应改为 go-judge 等真实沙箱
JUDGE_SANDBOX=local
# go-judge 服务地址（JUDGE_SANDBOX=go-judge 时使用；推荐生产环境）
GO_JUDGE_URL=http://127.0.0.1:5050
